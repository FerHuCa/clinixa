# NOTA: el script dev:api sourcea el .env con `set -a; . .env`. Las vars OPCIONALES sin
# valor deben quedar COMENTADAS en tu .env real: exportarlas vacías shadowa los fallbacks
# de Development del código (p.ej. MERCADOPAGO_WEBHOOK_SECRET="" rompe el "dev-webhook-secret").
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5050
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
NEXT_PUBLIC_ENABLE_DEV_AUTH=true
ConnectionStrings__HealthHubDb="Host=localhost;Port=5432;Database=healthhub;Username=healthhub;Password=healthhub_dev"
Clerk__SecretKey=
Clerk__Issuer=
Clerk__AuthorizedParties=http://localhost:3000
Web__AllowedOrigins=http://localhost:3000,http://localhost:3001
Web__BaseUrl=http://localhost:3000
# Envio de correo (opcional): si RESEND_API_KEY falta, los correos se simulan en el log
RESEND_API_KEY=
RESEND_FROM="Clinixa <no-reply@clinixa.mx>"
# Mercado Pago (opcional): sin MERCADOPAGO_ACCESS_TOKEN el checkout opera en modo simulado
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# En Development sin secreto se usa "dev-webhook-secret"; en produccion sin secreto el webhook rechaza todo
MERCADOPAGO_WEBHOOK_SECRET=
# Marketplace (split de pagos via OAuth): credenciales de la aplicacion MP tipo marketplace.
# Sin estas, la vinculacion de cuentas de profesionales opera en modo simulado
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# Cifrado de tokens OAuth en BD: base64 de 32 bytes (openssl rand -base64 32).
# En Development hay clave fija de respaldo; en produccion es obligatoria
ENCRYPTION_KEY=
